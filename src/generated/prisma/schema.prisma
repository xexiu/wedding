generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  ADMIN
}

enum GuestGroup {
  FAMILY
  FRIENDS
  WORK
  OTHER
}

enum RsvpStatus {
  PENDING
  ATTENDING
  DECLINED
}

model SiteConfig {
  id             Int      @id @default(1)
  templateId     String   @default("classic")
  cadencePreset  String   @default("mobile-balanced")
  themeTokens    Json?
  motionSettings Json?
  layoutSettings Json?
  moduleFlags    Json
  moduleOrder    Json
  weddingDetails Json
  moduleProps    Json
  updatedAt      DateTime @updatedAt
}

model LocaleConfig {
  code      String   @id
  name      String
  enabled   Boolean  @default(true)
  isDefault Boolean  @default(false)
  messages  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model EventConfig {
  id           Int       @id @default(1)
  rsvpDeadline DateTime?
  eventDetails Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Guest {
  id                  Int         @id @default(autoincrement())
  name                String
  email               String?
  phone               String?
  group               GuestGroup  @default(FRIENDS)
  rsvpStatus          RsvpStatus  @default(PENDING)
  dietaryRestrictions String?
  notes               String?
  plusOneCount        Int         @default(0)
  plusOneNames        Json?
  requestedSongs      Json?
  invitation          Invitation?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model Invitation {
  id        Int       @id @default(autoincrement())
  guestId   Int       @unique
  token     String    @unique
  sentAt    DateTime?
  openedAt  DateTime?
  guest     Guest     @relation(fields: [guestId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
